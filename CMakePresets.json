{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "FFB debug-build with ifx",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_Fortran_COMPILER": "ifx",
        "CMAKE_BUILD_TYPE": "Debug",
        "FFB_DENSITY_CHECKS": "ON",
        "FFB_FFB_BOUNDARY_CHECKS": "ON"
      }
    },
    {
      "name": "debug-fp64",
      "displayName": "FFB debug-build with ifx and real64",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug-fp64",
      "cacheVariables": {
        "CMAKE_Fortran_COMPILER": "ifx",
        "CMAKE_BUILD_TYPE": "Debug",
        "FFB_FP64": "ON",
        "FFB_DENSITY_CHECKS": "ON",
        "FFB_FFB_BOUNDARY_CHECKS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "FFB release-build with ifx",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_Fortran_COMPILER": "ifx",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-fp64",
      "displayName": "FFB release-build with ifx and real64",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release-fp64",
      "cacheVariables": {
        "CMAKE_Fortran_COMPILER": "ifx",
        "CMAKE_BUILD_TYPE": "Release",
        "FFB_FP64": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "debug-fp64",
      "configurePreset": "debug-fp64"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "release-fp64",
      "configurePreset": "release-fp64"
    }
  ]
}
